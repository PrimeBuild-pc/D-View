generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DiscordGuild {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     DiscordRole[]
  channels  DiscordChannel[]
  snapshots PermissionSnapshot[]
  plans     PermissionChangePlan[]
  findings  AuditFinding[]
}

model DiscordRole {
  id          String @id
  guildId     String
  guild       DiscordGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name        String
  color       String?
  position    Int
  managed     Boolean @default(false)
  permissions Json
  updatedAt   DateTime @updatedAt

  @@index([guildId])
}

model DiscordChannel {
  id         String @id
  guildId    String
  guild      DiscordGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  parentId   String?
  name       String
  type       String
  overwrites Json
  updatedAt  DateTime @updatedAt

  @@index([guildId])
  @@index([parentId])
}

model PermissionSnapshot {
  id        String @id @default(cuid())
  guildId   String
  guild     DiscordGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  version   String
  data      Json
  reason    String?
  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
}

model PermissionChangePlan {
  id        String @id @default(cuid())
  guildId   String
  guild     DiscordGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  createdByDiscordUserId String
  reason    String?
  status    String @default("draft")
  warnings  Json
  createdAt DateTime @default(now())
  operations PermissionChangeOperation[]
  executions PermissionChangeExecution[]
}

model PermissionChangeOperation {
  id       String @id @default(cuid())
  planId   String
  plan     PermissionChangePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  kind     String
  targetId String
  before   Json
  after    Json
  warnings Json
  included Boolean @default(true)
  order    Int
}

model PermissionChangeExecution {
  id        String @id @default(cuid())
  planId    String
  plan      PermissionChangePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  status    String
  result    Json
  startedAt DateTime @default(now())
  finishedAt DateTime?
}

model AuditFinding {
  id          String @id @default(cuid())
  guildId     String
  guild       DiscordGuild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  severity    String
  title       String
  description String
  channelId   String?
  roleId      String?
  createdAt   DateTime @default(now())

  @@index([guildId, severity])
}

